# Copy to `.env` and update values as needed.

# Stack4Things / Keystone
STACK4THINGS_ADMIN_USER=admin
STACK4THINGS_ADMIN_PASSWORD=s4t

KEYSTONE_DB_HOST=keystone-db.keystone.svc.cluster.local
KEYSTONE_DB_NAME=keystone
KEYSTONE_DB_USER=keystone
KEYSTONE_DB_PASSWORD=password_keystone
KEYSTONE_DB_ROOT_PASSWORD=root_password

# Keycloak
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

KEYCLOAK_DB_HOST=keycloak-db
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=password_keycloak

# IoTronic / MariaDB
IOTRONIC_DB_HOST=iotronic-db
IOTRONIC_DB_NAME=iotronic
IOTRONIC_DB_USER=iotronic
IOTRONIC_DB_PASSWORD=unime
IOTRONIC_DB_ROOT_PASSWORD=s4t

# RabbitMQ
RABBITMQ_DEFAULT_USER=openstack
RABBITMQ_DEFAULT_PASSWORD=unime

# Neutron & Designate (used inside iotronic.conf)
NEUTRON_PASSWORD=netrn_pwd
DESIGNATE_PASSWORD=password

# OIDC secrets (mod_auth_openidc in keystone wsgi config)
OIDC_CLIENT_SECRET=6OWR6HQAqfWQ2AES8S3uSsW3O52Mw4RJ
OIDC_CRYPTO_PASSPHRASE=password_lunga_e_casuale_per_sicurezza

# keystone-entrypoint.sh (OpenStack bootstrap/federation)
KEYSTONE_ENTRYPOINT_ADMIN_PASSWORD=admin
KEYSTONE_ENTRYPOINT_IOTRONIC_USER_PASSWORD=unime
S4T_PLATFORM_USER_PASSWORD=platform-secret

